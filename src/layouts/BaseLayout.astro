---
import "@/styles/globals.css";

import SEO from "@/components/additional/SEO.astro";
import { Navbar } from "@/components/layout/Navbar";
import { Footer } from "@/components/layout/Footer";
import { shouldShowSiteNav } from "@/lib/navigation";
import type { ArticleOpenGraph } from "@/lib/metadata";
import { siteConfig } from "@/lib/metadata";

interface Props {
  title: string;
  description: string;
  pathname: string;
  canonicalPath?: string;
  ogImage?: string;
  /** Passed to JSON-LD `Person.image` only (e.g. homepage headshot), not used as post cover art. */
  personSchemaImage?: string;
  article?: ArticleOpenGraph;
  supplementalStructuredData?: string;
  /** When true, left rail uses a translucent stack (e.g. full-bleed hero stacks). */
  overlayNavbar?: boolean;
}

const {
  title,
  description,
  pathname,
  canonicalPath,
  ogImage,
  personSchemaImage,
  article,
  supplementalStructuredData,
  overlayNavbar = false,
} = Astro.props;

const navbarVariant = overlayNavbar ? "overlay" : "static";
const canonical = new URL(canonicalPath ?? Astro.url.pathname, Astro.site ?? siteConfig.url);
const pathnameNormalized = (pathname.replace(/\/$/, "") || "/") as "/" | string;
const showSiteNav = shouldShowSiteNav(pathname);
const footerFlushTop = pathnameNormalized === "/" || pathnameNormalized === "/projects";
/** Avoid `main` stretching to fill the viewport when content is shorter — removes a dead band above the footer (common on `/projects` / iPad). */
const mainHugContent = pathnameNormalized === "/projects";
---

<!doctype html>
<html lang="en" class="h-full antialiased font-sans">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" href="/icons/favicon-32x32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/icons/favicon.svg" type="image/svg+xml" sizes="any" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" sizes="180x180" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="apple-mobile-web-app-title" content={siteConfig.name} />
    <meta name="theme-color" content="#f7efe3" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600;8..60,700&display=swap"
      rel="stylesheet"
    />
    <SEO
      title={title}
      description={description}
      canonical={canonical.href}
      image={ogImage}
      personSchemaImage={personSchemaImage}
      article={article}
      supplementalStructuredData={supplementalStructuredData}
    />
  </head>
  <body class="flex min-h-dvh flex-col">
    {showSiteNav && <Navbar client:load variant={navbarVariant} pathname={pathname} />}
    <div
      class:list={[
        "flex min-h-0 w-full min-w-0 flex-1 flex-col",
        showSiteNav && "pl-[var(--sidebar-width)] max-lg:pl-0",
      ]}
    >
      <main
        class:list={[
          "m-0 flex w-full min-w-0 flex-col p-0",
          !mainHugContent && "flex-1",
        ]}
      >
        <slot />
      </main>
      <Footer flushTop={footerFlushTop} />
    </div>
  </body>
</html>
