---
import { THOUGHT_FEED_PAGE_SIZE, THOUGHT_GENRE_LABEL, THOUGHT_GENRE_ORDER } from "@/lib/thoughts";

const defaultThoughtGenre = THOUGHT_GENRE_ORDER[0];
---

<script is:inline define:vars={{ THOUGHT_FEED_PAGE_SIZE, THOUGHT_GENRE_LABEL, defaultThoughtGenre }}>
  (function () {
    const PAGE_SIZE = THOUGHT_FEED_PAGE_SIZE;
    const FILTER_LABELS = THOUGHT_GENRE_LABEL;
    const DEFAULT_GENRE = defaultThoughtGenre;

    let currentThoughtFilter = DEFAULT_GENRE;
    let currentFeedPage = 1;

    function readThoughtFilterFromUrl() {
      try {
        const params = new URLSearchParams(window.location.search);
        const g = params.get("g");
        if (g === "spirituality" || g === "philosophy" || g === "science" || g === "additional") {
          return g;
        }
        if (g === "all") return DEFAULT_GENRE;
      } catch {
        /* ignore */
      }
      return DEFAULT_GENRE;
    }

    function readThoughtPageFromUrl() {
      try {
        const params = new URLSearchParams(window.location.search);
        const raw = params.get("p");
        const n = parseInt(raw || "1", 10);
        if (Number.isFinite(n) && n >= 1) return n;
      } catch {
        /* ignore */
      }
      return 1;
    }

    function syncThoughtUrl(filter, page) {
      try {
        if (!window.history || !window.history.replaceState) return;
        const params = new URLSearchParams();
        params.set("g", filter);
        if (page > 1) params.set("p", String(page));
        const q = params.toString();
        window.history.replaceState(null, "", q ? "/thoughts?" + q : "/thoughts");
      } catch {
        /* ignore */
      }
    }

    function updateFilterButtonStyles(filter) {
      document.querySelectorAll("[data-thought-filter]").forEach(function (btn) {
        const attr = btn.getAttribute("data-thought-filter") || DEFAULT_GENRE;
        const sel = attr === filter;
        btn.setAttribute("aria-pressed", sel ? "true" : "false");
        btn.className = sel ? "thought-btn-primary" : "thought-btn-filter-idle";
      });
      const toggleLabel = document.querySelector("[data-thought-genre-toggle-label]");
      if (toggleLabel && FILTER_LABELS && FILTER_LABELS[filter]) {
        toggleLabel.textContent = FILTER_LABELS[filter];
      }
    }

    function renderPageList(current, total) {
      const list = document.querySelector("[data-thought-page-list]");
      if (!list) return;
      list.innerHTML = "";

      function mkBtn(p, isSel) {
        const b = document.createElement("button");
        b.type = "button";
        b.textContent = String(p);
        b.setAttribute("aria-label", "Page " + p);
        if (isSel) b.setAttribute("aria-current", "page");
        b.className = isSel ? "thought-pager-page--primary" : "thought-pager-page--tertiary";
        b.addEventListener("click", function () {
          applyThoughtView(currentThoughtFilter, p);
          syncThoughtUrl(currentThoughtFilter, p);
        });
        list.appendChild(b);
      }

      function mkEll() {
        const s = document.createElement("span");
        s.className = "px-1 text-base font-medium text-foreground-muted sm:px-2";
        s.textContent = "…";
        s.setAttribute("aria-hidden", "true");
        list.appendChild(s);
      }

      if (total <= 7) {
        for (let i = 1; i <= total; i++) mkBtn(i, i === current);
      } else if (current <= 3) {
        for (let i = 1; i <= 4; i++) mkBtn(i, i === current);
        mkEll();
        mkBtn(total, current === total);
      } else if (current >= total - 2) {
        mkBtn(1, current === 1);
        mkEll();
        for (let i = total - 3; i <= total; i++) mkBtn(i, i === current);
      } else {
        mkBtn(1, false);
        mkEll();
        mkBtn(current - 1, false);
        mkBtn(current, true);
        mkBtn(current + 1, false);
        mkEll();
        mkBtn(total, false);
      }
    }

    function applyThoughtView(filter, page) {
      currentThoughtFilter = filter;
      const items = Array.from(document.querySelectorAll("[data-thought-item]"));
      const empty = document.querySelector("[data-thought-empty]");
      const pagination = document.querySelector("[data-thought-pagination]");
      const prevBtn = document.querySelector("[data-thought-page-prev]");
      const nextBtn = document.querySelector("[data-thought-page-next]");

      const matching = items.filter(function (el) {
        const g = el.getAttribute("data-thought-genre");
        return g === filter;
      });

      const totalPages = Math.max(1, Math.ceil(matching.length / PAGE_SIZE));
      const pageNum = Math.min(Math.max(1, page || 1), totalPages);
      currentFeedPage = pageNum;

      items.forEach(function (el) {
        el.classList.add("hidden");
      });

      const start = (pageNum - 1) * PAGE_SIZE;
      matching.slice(start, start + PAGE_SIZE).forEach(function (el) {
        el.classList.remove("hidden");
      });

      let visibleCount = 0;
      document.querySelectorAll("[data-thought-featured]").forEach(function (featuredEl) {
        const fg = featuredEl.getAttribute("data-thought-genre");
        const showF = fg === filter;
        featuredEl.classList.toggle("hidden", !showF);
        if (showF) visibleCount += 1;
      });
      visibleCount += matching.slice(start, start + PAGE_SIZE).length;

      if (empty) empty.classList.toggle("hidden", visibleCount > 0);

      updateFilterButtonStyles(filter);

      if (pagination) {
        pagination.classList.toggle("hidden", totalPages <= 1);
        renderPageList(pageNum, totalPages);
      }
      if (prevBtn) prevBtn.disabled = pageNum <= 1;
      if (nextBtn) nextBtn.disabled = pageNum >= totalPages;

      try {
        requestAnimationFrame(function () {
          window.dispatchEvent(new CustomEvent("thoughts-hub-scroll-refresh"));
        });
      } catch {
        /* ignore */
      }
    }

    document.querySelectorAll("[data-thought-filter]").forEach(function (btn) {
      btn.addEventListener("click", function () {
        const v = btn.getAttribute("data-thought-filter");
        if (!v) return;
        applyThoughtView(v, 1);
        syncThoughtUrl(v, 1);
        const genreDetails = document.querySelector("[data-thought-genre-details]");
        if (genreDetails) genreDetails.open = false;
      });
    });

    const prevBtn = document.querySelector("[data-thought-page-prev]");
    const nextBtn = document.querySelector("[data-thought-page-next]");
    if (prevBtn) {
      prevBtn.addEventListener("click", function () {
        if (currentFeedPage <= 1) return;
        const nextP = currentFeedPage - 1;
        applyThoughtView(currentThoughtFilter, nextP);
        syncThoughtUrl(currentThoughtFilter, nextP);
      });
    }
    if (nextBtn) {
      nextBtn.addEventListener("click", function () {
        applyThoughtView(currentThoughtFilter, currentFeedPage + 1);
        syncThoughtUrl(currentThoughtFilter, currentFeedPage);
      });
    }

    const initialFilter = readThoughtFilterFromUrl();
    const initialPage = readThoughtPageFromUrl();
    applyThoughtView(initialFilter, initialPage);
    syncThoughtUrl(currentThoughtFilter, currentFeedPage);

    const filterChrome = document.querySelector(".thought-genre-chrome");
    const filterSpacer = document.querySelector("[data-dashboard-filter-spacer]");
    let filterSpacerTicking = false;
    function syncThoughtFilterSpacer() {
      if (!filterChrome || !filterSpacer) return;
      filterSpacer.style.height = filterChrome.offsetHeight + "px";
    }
    function onThoughtFilterSpacerResize() {
      if (filterSpacerTicking) return;
      filterSpacerTicking = true;
      requestAnimationFrame(function () {
        syncThoughtFilterSpacer();
        filterSpacerTicking = false;
      });
    }
    if (filterChrome && filterSpacer) {
      window.addEventListener("resize", onThoughtFilterSpacerResize, { passive: true });
      syncThoughtFilterSpacer();
      requestAnimationFrame(syncThoughtFilterSpacer);
      window.addEventListener("load", syncThoughtFilterSpacer, { once: true });
    }

    const genreDetailsEl = document.querySelector("[data-thought-genre-details]");
    if (genreDetailsEl) {
      genreDetailsEl.addEventListener("toggle", function () {
        syncThoughtFilterSpacer();
        requestAnimationFrame(syncThoughtFilterSpacer);
      });
    }
  })();
</script>
