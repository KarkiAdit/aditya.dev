---
import { pageStackSectionIntroToBodyFlexGapClass } from "@/lib/site-page-layout";
import { siteChromeGutters, siteChromeInnerFullWidth } from "@/lib/site-chrome";
import { cn } from "@/lib/utils";
---

<div
  slot="fallback"
  class={cn(siteChromeGutters, "w-full")}
  role="status"
  aria-live="polite"
  aria-busy="true"
  aria-label="Loading more about me"
>
  <div
    class={cn(
      siteChromeInnerFullWidth,
      "flex flex-col py-8 md:py-10",
      pageStackSectionIntroToBodyFlexGapClass,
    )}
  >
    <div class="flex flex-col gap-2" aria-hidden="true">
      <div class="h-3 w-28 animate-pulse rounded bg-muted/40"></div>
      <div class="h-10 max-w-md animate-pulse rounded-xl bg-muted/50 sm:h-11 md:h-12"></div>
    </div>
    <div
      class="flex flex-col items-center gap-10 md:flex-row md:items-stretch md:justify-between md:gap-8"
      aria-hidden="true"
    >
      <div class="mx-auto flex min-h-[28rem] w-full max-w-[min(24rem,92vw)] shrink-0 animate-pulse rounded-xl bg-muted/25 md:mx-0 md:max-w-[min(28rem,48%)] lg:max-w-[min(30rem,46%)]" />
      <div class="flex min-h-[12rem] w-full max-w-md flex-1 flex-col items-center gap-3 md:max-w-none md:items-stretch">
        <div class="h-24 w-full animate-pulse rounded-lg bg-muted/30"></div>
        <div class="h-10 w-48 animate-pulse rounded-full bg-muted/35"></div>
      </div>
    </div>
  </div>
</div>
