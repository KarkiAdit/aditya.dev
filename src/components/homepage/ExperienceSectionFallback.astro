---
import { pageStackSectionIntroToBodySpacingClass } from "@/lib/site-page-layout";
import { siteChromeGutters, siteChromeInner } from "@/lib/site-chrome";
import { cn } from "@/lib/utils";
---

<div class={cn(siteChromeGutters, "w-full")} role="status"
  aria-live="polite"
  aria-busy="true"
  aria-label="Loading works and profile"
>
  <div class={cn(siteChromeInner, "mx-auto max-w-6xl py-0")}>
    <div class={cn("flex flex-col gap-2", pageStackSectionIntroToBodySpacingClass)} aria-hidden="true">
      <div class="h-3 w-32 animate-pulse rounded bg-muted/40"></div>
      <div class="h-10 max-w-md animate-pulse rounded-xl bg-muted/50 sm:h-11 md:h-12"></div>
    </div>
    <div class="mt-8 flex w-full min-w-0 flex-col gap-8 sm:mt-10 sm:gap-10 md:mt-12" aria-hidden="true">
      <div class="w-full min-w-0 pt-1">
        <div class="relative min-w-0 w-full">
          <div class="pointer-events-none absolute right-[10%] top-[10%] z-20" aria-hidden="true">
            <div
              class="pointer-events-none inline-flex max-w-[min(100%,30rem)] min-h-0 flex-row items-center gap-3.5 rounded-2xl border border-secondary/35 bg-card/92 px-3.5 py-3 text-foreground shadow-sm ring-1 ring-inset ring-secondary/20 sm:gap-4 sm:px-4 sm:py-3.5 md:px-5 md:py-4"
            >
              <div class="size-16 shrink-0 rounded-full border border-secondary/40 bg-secondary/35 sm:size-20"></div>
              <div class="h-4 w-24 shrink-0 rounded-md bg-muted/40 sm:h-5 sm:w-28"></div>
            </div>
          </div>
          <div class="min-w-0 px-2 pb-0 pt-2 sm:px-3 md:px-4">
        <div
          class="w-full min-w-0 overflow-hidden rounded-2xl border border-primary/20 bg-card/70 px-3 pt-4 pb-0 text-foreground shadow-sm ring-1 ring-inset ring-secondary/35 backdrop-blur-xl sm:px-5 sm:pt-5 sm:pb-0"
          aria-hidden="true"
        >
        <div
          class="grid w-full min-w-0 grid-cols-[minmax(3rem,3.75rem)_1fr] grid-rows-[auto_auto] gap-x-2 gap-y-0 sm:gap-x-3"
        >
          <div class="row-start-1 flex min-h-[45vh] flex-col justify-between self-stretch pt-1 pr-1.5 text-heading sm:pr-2">
            <div class="h-3 w-9 self-end animate-pulse rounded bg-muted/40 sm:h-3.5 sm:w-10"></div>
            <div class="h-3 w-8 self-end animate-pulse rounded bg-muted/35 sm:h-3.5 sm:w-9"></div>
            <div class="h-3 w-6 self-end animate-pulse rounded bg-muted/35 sm:h-3.5"></div>
          </div>
          <div class="row-start-1 flex min-h-[45vh] min-w-0 flex-col border-b-2 border-l-2 border-heading/45 pl-2 sm:pl-2.5">
            <div class="grid min-h-[45vh] w-full flex-1 gap-1.5 sm:gap-2 md:gap-3" style="grid-template-columns: repeat(6, minmax(0, 1fr));">
              {
                [55, 88, 38, 72, 95, 48].map((pct) => (
                  <div class="flex h-full min-h-0 min-w-0 flex-col justify-end self-stretch">
                    <div class="mx-auto flex h-full min-h-0 w-full max-w-[3.25rem] flex-col justify-end sm:max-w-[3.75rem]">
                      <div
                        class="w-full animate-pulse rounded-none bg-muted/50"
                        style={{ height: `${pct}%` }}
                      />
                    </div>
                  </div>
                ))
              }
            </div>
          </div>
          <div class="row-start-2 col-start-1"></div>
          <div class="row-start-2 min-w-0 pt-2 pb-2 sm:pb-2.5 md:pb-3">
            <div class="grid w-full gap-1.5 sm:gap-2" style="grid-template-columns: repeat(6, minmax(0, 1fr));">
              {
                Array.from({ length: 6 }).map(() => (
                  <div class="flex min-w-0 flex-col items-center gap-1.5">
                    <div class="h-4 w-14 max-w-full animate-pulse rounded bg-muted/40 sm:h-5 sm:w-16"></div>
                    <div class="h-3.5 w-10 animate-pulse rounded bg-muted/35 sm:h-4 sm:w-12"></div>
                  </div>
                ))
              }
            </div>
            <div class="mx-auto mt-3 h-3.5 w-20 animate-pulse rounded bg-muted/50 sm:h-4 sm:w-28"></div>
          </div>
        </div>
        </div>
          </div>
        </div>
      </div>
    </div>
    <div
      class="mt-12 min-h-[28rem] w-full animate-pulse rounded-xl bg-muted/20 sm:mt-16"
      aria-hidden="true"
    >
    </div>
  </div>
</div>
