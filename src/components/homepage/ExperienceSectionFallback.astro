---
import { siteChromeGutters, siteChromeInner } from "@/lib/site-chrome";
import { cn } from "@/lib/utils";
---

<div class={cn(siteChromeGutters, "w-full")} role="status"
  aria-live="polite"
  aria-busy="true"
  aria-label="Loading works and profile"
>
  <div class={cn(siteChromeInner, "mx-auto max-w-6xl py-0")}>
    <div class="mb-10 flex flex-col gap-2" aria-hidden="true">
      <div class="h-3 w-32 animate-pulse rounded bg-muted/40"></div>
      <div class="h-10 max-w-md animate-pulse rounded-xl bg-muted/50 sm:h-11 md:h-12"></div>
    </div>
    <div class="grid gap-12 lg:grid-cols-[minmax(0,22rem)_1fr] lg:items-start lg:gap-16">
      <div class="flex flex-col items-center gap-6 text-center lg:sticky lg:top-[calc(var(--navbar-height)+1.5rem)]">
        <div
          class="aspect-square w-[min(100%,18rem)] animate-pulse rounded-full bg-muted/50 ring-2 ring-border/15 ring-offset-2 ring-offset-transparent sm:w-[min(100%,20rem)] md:w-[min(100%,22rem)] lg:w-full lg:max-w-[22rem]"
          aria-hidden="true"
        >
        </div>
        <div class="flex w-full max-w-xs flex-col items-center gap-3">
          <div class="h-8 w-48 animate-pulse rounded-lg bg-muted/50" aria-hidden="true"></div>
          <div class="h-10 w-full max-w-xs animate-pulse rounded-full bg-muted/40" aria-hidden="true"></div>
        </div>
      </div>
      <div class="flex min-w-0 flex-col gap-6" aria-hidden="true">
        <div>
          <div class="h-3 w-24 animate-pulse rounded bg-muted/40"></div>
          <div class="mt-4 h-4 w-full animate-pulse rounded-full bg-muted/45"></div>
          <div class="mt-3 flex flex-wrap gap-3">
            <div class="h-3 w-16 animate-pulse rounded bg-muted/35"></div>
            <div class="h-3 w-20 animate-pulse rounded bg-muted/35"></div>
            <div class="h-3 w-14 animate-pulse rounded bg-muted/35"></div>
          </div>
        </div>
        <div class="h-10 w-full animate-pulse rounded-full bg-muted/40"></div>
        <ul class="grid min-w-0 list-none gap-3 p-0 sm:grid-cols-2 lg:grid-cols-3">
          {
            [0, 1, 2, 3, 4, 5].map(() => (
              <li>
                <div class="flex h-full min-h-[7.5rem] flex-col rounded-2xl border border-border/20 bg-card/30 p-4 ring-1 ring-inset ring-white/5">
                  <div class="h-4 w-[75%] max-w-[12rem] animate-pulse rounded bg-muted/45"></div>
                  <div class="mt-3 h-3 w-full animate-pulse rounded bg-muted/35"></div>
                  <div class="mt-2 h-3 w-[83%] animate-pulse rounded bg-muted/30"></div>
                  <div class="mt-auto flex gap-2 pt-3">
                    <div class="h-5 w-14 animate-pulse rounded-full bg-muted/40"></div>
                    <div class="h-5 w-12 animate-pulse rounded-full bg-muted/35"></div>
                  </div>
                </div>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
    <div
      class="mt-12 min-h-[28rem] w-full animate-pulse rounded-xl bg-muted/20 sm:mt-16"
      aria-hidden="true"
    >
    </div>
  </div>
</div>
