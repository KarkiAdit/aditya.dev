---
import HomeKnowledgeContent from "@/components/homepage/HomeKnowledgeContent.astro";
import type { CurrentFocusBookCard } from "@/lib/current-focus-books";
import { pageStackKnowledgeSlabContentPaddingClass } from "@/lib/site-page-layout";
import { siteChromeGutters, siteChromeInnerFullWidth } from "@/lib/site-chrome";
import { cn } from "@/lib/utils";

interface Props {
  currentFocusBooks: readonly CurrentFocusBookCard[];
  className?: string;
}

const { currentFocusBooks, className } = Astro.props;
---

<div class={cn("w-full bg-transparent", className)}>
  <div class={cn(siteChromeGutters)}>
    <div
      class={cn(siteChromeInnerFullWidth, pageStackKnowledgeSlabContentPaddingClass)}
    >
      <HomeKnowledgeContent currentFocusBooks={currentFocusBooks} />
    </div>
  </div>
</div>

