---
import {
  HERO_STACK_BANNER_FRAME_CLASS,
  HERO_STACK_BANNER_IMG_CLASS,
  HERO_STACK_BANNER_SECTION_CLASS,
  HERO_STACK_BANNER_SECTION_CLASS_MATCH_BODY,
  HERO_STACK_BANNER_SMALL_MEDIA,
} from "@/lib/homepage/hero-stack-banner";

interface Props {
  imageSrc: string;
  imageSrcSmall: string;
  imageAlt: string;
  sectionAriaLabel: string;
  /** Homepage `/` — strip frosted slab so the hero sits on the same canvas as `body`. */
  matchBody?: boolean;
}

const { imageSrc, imageSrcSmall, imageAlt, sectionAriaLabel, matchBody = false } = Astro.props;

const sectionShellClass = matchBody ? HERO_STACK_BANNER_SECTION_CLASS_MATCH_BODY : HERO_STACK_BANNER_SECTION_CLASS;
---

<div class:list={[sectionShellClass]} role="region" aria-label={sectionAriaLabel}>
  <div class:list={[HERO_STACK_BANNER_FRAME_CLASS]}>
    <picture>
      <source media={HERO_STACK_BANNER_SMALL_MEDIA} srcset={imageSrcSmall} />
      <img
        src={imageSrc}
        alt={imageAlt}
        class:list={[HERO_STACK_BANNER_IMG_CLASS]}
        decoding="async"
        fetchpriority="high"
      />
    </picture>
  </div>
</div>
