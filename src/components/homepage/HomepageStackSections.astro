---
import {
  HOMEPAGE_STACK_ROLE,
  homepageStackLayout,
} from "@/lib/homepage/homepage-stack";
---

<div class={homepageStackLayout.column}>
  <div class={homepageStackLayout.heroSlab}>
    <div
      class={homepageStackLayout.heroPanel}
      data-homepage-stack-panel={HOMEPAGE_STACK_ROLE.hero}
    >
      <slot name="hero" />
    </div>
  </div>
  <div class={homepageStackLayout.aboutSlab}>
    <div
      class={homepageStackLayout.surfacePanel}
      data-homepage-stack-panel={HOMEPAGE_STACK_ROLE.surface}
    >
      <slot name="about" />
    </div>
  </div>
  <div class={homepageStackLayout.roadmapSlab}>
    <div
      class={homepageStackLayout.surfaceDeepPanel}
      data-homepage-stack-panel={HOMEPAGE_STACK_ROLE.surface}
    >
      <slot name="roadmap" />
    </div>
  </div>
  <div class={homepageStackLayout.memoryLaneSlab}>
    <div
      class={homepageStackLayout.surfaceDeepPanel}
      data-homepage-stack-panel={HOMEPAGE_STACK_ROLE.surface}
    >
      <slot name="memory" />
    </div>
  </div>
</div>
