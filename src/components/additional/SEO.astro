---
import type { ArticleOpenGraph } from "@/lib/metadata";
import { robotsMetaContent, siteConfig, siteJsonLd } from "@/lib/metadata";

interface Props {
  title: string;
  description: string;
  canonical: string;
  /** Open Graph / Twitter image only (e.g. post cover or homepage hero). */
  image?: string;
  /**
   * Optional stable image for JSON-LD `Person` only (e.g. author headshot).
   * Do not pass article art here — it is not the person's identity photo.
   */
  personSchemaImage?: string;
  /** When set, `og:type` is `article` and `article:*` tags are emitted (essay / blog posts). */
  article?: ArticleOpenGraph;
  /** Extra JSON-LD (e.g. WebPage + BreadcrumbList for legal pages). Must be a full serialized object. */
  supplementalStructuredData?: string;
}

const { title, description, canonical, image, personSchemaImage, article, supplementalStructuredData } = Astro.props;
const structuredData = siteJsonLd({ personImage: personSchemaImage });
const ogType = article ? "article" : "website";
---

<link rel="canonical" href={canonical} />
<title>{title}</title>
<meta name="description" content={description} />
<meta property="og:type" content={ogType} />
<meta property="og:locale" content="en_US" />
<meta property="og:url" content={canonical} />
<meta property="og:site_name" content={siteConfig.name} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
{article ? <meta property="article:published_time" content={article.publishedTime} /> : null}
{article?.modifiedTime ? <meta property="article:modified_time" content={article.modifiedTime} /> : null}
{image ? <meta property="og:image" content={image} /> : null}
<meta name="twitter:card" content={image ? "summary_large_image" : "summary"} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{image ? <meta name="twitter:image" content={image} /> : null}
<meta name="robots" content={robotsMetaContent()} />
<meta name="author" content={siteConfig.author} />
<script type="application/ld+json" set:html={structuredData} />
{supplementalStructuredData ? (
  <script type="application/ld+json" set:html={supplementalStructuredData} />
) : null}
