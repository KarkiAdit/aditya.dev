---
import type { CurrentFocusBookCard } from "@/lib/current-focus-books";
import { githubDashboardRepoCardClassName } from "@/lib/github-dashboard-card";
import { featuredNicheDescriptionTypography } from "@/lib/link-styles";
import { cn } from "@/lib/utils";

interface Props {
  currentFocusBooks: readonly CurrentFocusBookCard[];
}

const { currentFocusBooks } = Astro.props;

/** Same frosted “whitish” tile as GitHub repo cards on this page (`githubDashboardRepoCardClassName`). */
const bookCardClassName = cn(githubDashboardRepoCardClassName, "min-w-0 p-3 sm:p-4");

const bookCoverFrameClassName = cn(
  "relative aspect-[2/2.7] w-full overflow-hidden rounded-xl",
  "border border-border/30 bg-card-subtle ring-1 ring-inset ring-white/20",
);
---

<section
  class="relative min-w-0 bg-transparent p-0"
  id="knowledge"
  aria-labelledby="current-focus-heading"
>
  <article class="relative min-w-0 bg-transparent p-0">
    <header class="mb-8 flex flex-col gap-3 sm:mb-10">
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-foreground-muted">Career</p>
        <h2
          id="current-focus-heading"
          class={cn(
            featuredNicheDescriptionTypography,
            "mt-2 font-extrabold tracking-tight",
            "text-lg sm:text-xl md:text-2xl lg:text-3xl xl:text-4xl",
          )}
        >
          I’m endlessly fascinated by the intersection of complex system design and the human stories behind
          world-changing innovation.
        </h2>
      </div>
    </header>

    <div
      class="flex min-w-0 flex-col items-center gap-3 sm:grid sm:grid-cols-3 sm:items-stretch"
    >
      {
        currentFocusBooks.map((book: CurrentFocusBookCard) => (
          <a
            href={book.href}
            target="_blank"
            rel="noopener noreferrer"
            class={cn(
              bookCardClassName,
              "group w-full max-w-[350px] flex-col no-underline sm:max-w-none",
              "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring/40",
            )}
            aria-label={`${book.title} by ${book.author} (opens in a new tab)`}
          >
            <div class={bookCoverFrameClassName}>
              {book.cover ? (
                <img
                  src={book.cover.src}
                  width={book.cover.width}
                  height={book.cover.height}
                  alt=""
                  class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div class="flex h-full w-full items-center justify-center px-3">
                  <span class="text-center text-sm font-semibold uppercase tracking-widest text-foreground-muted/75 sm:text-base">
                    Cover
                  </span>
                </div>
              )}
            </div>
            <div class="mt-3 min-w-0">
              <p class="text-pretty text-base font-extrabold leading-snug text-secondary-foreground sm:text-lg">
                {book.title}
              </p>
              <p class="mt-1.5 text-pretty text-sm leading-snug text-secondary-foreground/90 sm:text-base">
                {book.author}
              </p>
              <p class="mt-2.5 text-base font-semibold text-secondary-foreground transition-colors group-hover:text-foreground sm:text-lg">
                View book →
              </p>
            </div>
          </a>
        ))
      }
    </div>
  </article>
</section>
