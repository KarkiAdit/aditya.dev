---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteChromeGutters, siteChromeInner } from "@/lib/site-chrome";
import { siteConfig } from "@/lib/metadata";

const title = `Projects · ${siteConfig.name}`;
const description = "Selected work — coming soon.";
---

<BaseLayout title={title} description={description} pathname={Astro.url.pathname}>
  <section class:list={[siteChromeGutters, siteChromeInner, "py-16"]}>
    <h1 class="heading-gradient text-3xl font-extrabold tracking-tighter sm:text-4xl">Projects</h1>
    <p class="mt-4 max-w-xl text-pretty text-foreground-muted">
      Project MDX lives in <code class="font-mono text-sm text-card-foreground">content/projects</code>.
      Build out this page with <code class="font-mono text-sm text-card-foreground">getCollection(&quot;projects&quot;)</code> when
      you want the dashboard back.
    </p>
  </section>
</BaseLayout>
