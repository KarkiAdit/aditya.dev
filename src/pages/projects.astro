---
import { getImage } from "astro:assets";
import { render } from "astro:content";

import BaseLayout from "@/layouts/BaseLayout.astro";
import ProjectsDashboard from "@/components/projects/ProjectsDashboard.astro";
import professionalHeadshot from "@/assets/images/additional/professional-headshot.jpeg";
import { formatDocumentTitle } from "@/lib/metadata";
import { fetchGithubDashboard } from "@/lib/github-dashboard";
import { GITHUB_SNAPSHOT_PICK_ID } from "@/lib/featured-niche-projects";
import { mdxArticleBodyClass } from "@/lib/mdx-article-body";
import {
  collectionEntryToFeaturedNicheProject,
  getSortedProjectEntries,
  projectEntryHasMdxBody,
  validDashboardProjectPickIds,
} from "@/lib/projects-content";
import { getFeaturedNichePublicImageMap } from "@/lib/projects-assets";

const title = formatDocumentTitle("Projects");
const description = "A projects dashboard: current reading and featured work.";

const githubLogin = import.meta.env.PUBLIC_GITHUB_LOGIN?.trim() ?? "";
const githubDashboardPromise =
  githubLogin.length > 0
    ? fetchGithubDashboard(githubLogin, import.meta.env.GITHUB_TOKEN)
    : Promise.resolve({
        ok: false as const,
        error: "Set PUBLIC_GITHUB_LOGIN in your environment to load your GitHub profile on this page.",
      });

const projectEntries = await getSortedProjectEntries();
const projectIds = validDashboardProjectPickIds(projectEntries);
const defaultBestPickId = projectEntries[0]?.id ?? GITHUB_SNAPSHOT_PICK_ID;

const projectPanels = await Promise.all(
  projectEntries.map(async (entry) => ({
    project: collectionEntryToFeaturedNicheProject(entry),
    hasMdxBody: projectEntryHasMdxBody(entry),
    Content: (await render(entry)).Content,
  })),
);

const nicheScreenshotSrc = getFeaturedNichePublicImageMap();
const [githubDashboardAvatar, githubDashboardResult] = await Promise.all([
  getImage({ src: professionalHeadshot, width: 960, format: "webp" }),
  githubDashboardPromise,
]);

const pickParam = Astro.url.searchParams.get("pick")?.trim() ?? "";
const validDashboardPickIds = new Set<string>([...projectIds, GITHUB_SNAPSHOT_PICK_ID]);
const initialBestPickId =
  pickParam && validDashboardPickIds.has(pickParam) ? pickParam : defaultBestPickId;
const surfShelterResearchFromEnv =
  typeof import.meta.env.PUBLIC_SURF_SHELTER_RESEARCH_URL === "string"
    ? import.meta.env.PUBLIC_SURF_SHELTER_RESEARCH_URL.trim()
    : "";
---

<BaseLayout title={title} description={description} pathname={Astro.url.pathname}>
  <ProjectsDashboard
    projectPanels={projectPanels}
    mdxBodyClass={mdxArticleBodyClass}
    nicheScreenshotSrc={nicheScreenshotSrc}
    surfShelterResearchFromEnv={surfShelterResearchFromEnv}
    initialPickId={initialBestPickId}
    githubDashboardResult={githubDashboardResult}
    githubDashboardAvatarSrc={githubDashboardAvatar.src}
  />
</BaseLayout>
