---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PlaceholderPageSection from "@/components/PlaceholderPageSection.astro";
import { formatDocumentTitle } from "@/lib/metadata";
import { PLACEHOLDER_PAGE_META_DESCRIPTION } from "@/lib/placeholder-page";

const title = formatDocumentTitle("Projects");
const description = PLACEHOLDER_PAGE_META_DESCRIPTION;
---

<BaseLayout title={title} description={description} pathname={Astro.url.pathname}>
  <PlaceholderPageSection heading="Projects" />
</BaseLayout>
