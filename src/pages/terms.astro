---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageStackBody from "@/components/layout/PageStackBody.astro";
import {
  LEGAL_PAGES_LAST_UPDATED,
  formatDocumentTitle,
  formatLegalDateDisplay,
  legalPageStructuredData,
  siteConfig,
} from "@/lib/metadata";
import { mdxArticleBodyClass } from "@/lib/mdx-article-body";

const title = formatDocumentTitle("Terms of Use");
const description =
  "Terms of Use for adityakarki.me — Aditya Karki’s personal site for software engineering projects and essays on consciousness and philosophy. Rules for use, content rights, external links, liability, and contact.";
const canonicalHref = new URL(Astro.url.pathname, Astro.site ?? siteConfig.url).href;
const supplementalStructuredData = legalPageStructuredData({
  canonicalHref,
  headline: "Terms of Use",
  description,
  dateModified: LEGAL_PAGES_LAST_UPDATED,
});
const lastUpdatedLabel = formatLegalDateDisplay(LEGAL_PAGES_LAST_UPDATED);

const thoughtPostPageShellClass =
  "nav-rail-icon-group-surface flex min-h-0 min-w-0 flex-1 flex-col";

const mediumDekClass =
  "max-w-none font-sans text-xl font-normal leading-snug text-foreground-muted md:text-2xl md:leading-snug";

const mediumMetaClass = "font-sans text-sm font-normal text-foreground-muted";

const mdxProseClass = mdxArticleBodyClass;
---

<BaseLayout
  title={title}
  description={description}
  pathname={Astro.url.pathname}
  supplementalStructuredData={supplementalStructuredData}
>
  <PageStackBody
    stackVariant="plain"
    plainTopPadding="compact"
    wrapInnerColumn={false}
    outerColumnClass={thoughtPostPageShellClass}
  >
    <article
      class:list={[
        "thought-article-shell thought-article-medium flex w-full min-w-0 flex-col gap-8 bg-transparent px-5 py-8 sm:gap-9 sm:px-8 sm:py-10 md:gap-10 md:px-10 md:py-12",
      ]}
    >
      <header class="flex min-w-0 flex-col gap-4 sm:gap-5">
        <p class="thought-article-kicker m-0 font-sans">Legal</p>

        <h1
          class="m-0 text-balance font-sans text-[2.25rem] font-bold leading-[1.12] tracking-tight text-heading sm:text-[2.5rem] md:text-[2.75rem] md:leading-[1.1]"
        >
          Terms of Use
        </h1>

        <p class:list={["m-0", mediumDekClass]}>
          These terms apply when you use
          <strong class="font-semibold text-foreground">{siteConfig.url.replace(/^https?:\/\//, "")}</strong>
          ({siteConfig.name}&rsquo;s personal site). They are written in plain language alongside the
          <a
            href="/privacy-policy"
            class="font-medium text-foreground underline decoration-[#6b6b6b]/40 underline-offset-4 transition-colors hover:decoration-[#242424] focus-visible:rounded-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#242424]/25"
            >Privacy Policy</a
          >.
        </p>

        <div
          class:list={[
            "flex flex-wrap items-center gap-x-2 gap-y-2 border-b border-[#e6e6e6] pb-6 sm:pb-7",
            mediumMetaClass,
          ]}
        >
          <a
            href="/"
            class="font-sans font-medium text-[#6b6b6b] underline-offset-4 transition-colors hover:text-[#242424] focus-visible:rounded-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#242424]/25"
          >
            Home
          </a>
          <span class="text-[#6b6b6b]/50" aria-hidden="true">
            ·
          </span>
          <a
            href="/privacy-policy"
            class="font-sans font-medium text-[#6b6b6b] underline-offset-4 transition-colors hover:text-[#242424] focus-visible:rounded-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#242424]/25"
          >
            Privacy Policy
          </a>
          <span class="text-[#6b6b6b]/50 max-sm:hidden" aria-hidden="true">
            ·
          </span>
          <span class="max-sm:mt-1 max-sm:w-full sm:inline">
            <time class="text-[#6b6b6b]" datetime={LEGAL_PAGES_LAST_UPDATED}>
              Last updated {lastUpdatedLabel}
            </time>
          </span>
        </div>
      </header>

      <hr class="m-0 h-px w-full border-0 bg-[#e6e6e6]" />

      <div class="min-w-0" role="region" aria-label="Terms of use body">
        <div
          class:list={[
            ...mdxProseClass,
            "[&>h2:first-of-type]:!mt-0 sm:[&>h2:first-of-type]:!mt-0 md:[&>h2:first-of-type]:!mt-0",
          ]}
        >
          <h2>Using this site</h2>
          <p>
            By browsing or using this site, you agree to these terms. If you do not agree, please stop using the site. The site is
            offered as a <strong class="font-semibold text-foreground">personal portfolio and writing space</strong>; it is not a
            commercial platform, store, or service provider for third parties.
          </p>

          <h2>Information, not advice</h2>
          <p>
            Posts, project descriptions, and other text are <strong class="font-semibold text-foreground">for general information
            only</strong>. They are not legal, financial, medical, or professional advice. You are responsible for how you use
            any ideas or links you find here.
          </p>

          <h2>Content and rights</h2>
          <p>
            Unless otherwise noted, original writing, design, and media on this site are owned by the site author or used with
            permission. You may read and share links to pages in the usual way; please do not copy large portions of the site,
            scrape it for training or bulk reuse, or imply endorsement without permission.
          </p>

          <h2>External sites</h2>
          <p>
            Links may take you to <strong class="font-semibold text-foreground">third-party sites</strong> (for example GitHub,
            Notion, or social profiles). Those sites have their own terms and privacy practices. This site is not responsible for
            their content or availability.
          </p>

          <h2>Limitation of liability</h2>
          <p>
            To the fullest extent allowed by law, the site owner is not liable for any indirect or consequential damages arising
            from your use of the site or reliance on its content. Some jurisdictions do not allow certain limitations; in those
            cases, only the minimum restrictions apply.
          </p>

          <h2>Changes</h2>
          <p>
            These terms may be updated as the site evolves. The footer links point to the current Legal pages. Continued use
            after changes means you accept the updated terms.
          </p>

          <h2>Questions</h2>
          <p>
            For questions about these terms or the site, use the social links in the footer.
          </p>
        </div>
      </div>
    </article>
  </PageStackBody>
</BaseLayout>
