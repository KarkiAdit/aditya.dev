---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteChromeGutters, siteChromeInner } from "@/lib/site-chrome";
import { siteConfig } from "@/lib/metadata";

const title = `Terms · ${siteConfig.name}`;
const description = "Terms of use placeholder.";
---

<BaseLayout title={title} description={description} pathname={Astro.url.pathname}>
  <section class:list={[siteChromeGutters, siteChromeInner, "py-16"]}>
    <h1 class="heading-gradient text-3xl font-extrabold tracking-tighter sm:text-4xl">Terms</h1>
    <p class="mt-4 text-foreground-muted">Replace this stub with your legal copy.</p>
  </section>
</BaseLayout>
