---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteChromeGutters, siteChromeInner } from "@/lib/site-chrome";
import { siteConfig } from "@/lib/metadata";

const title = `My Thoughts · ${siteConfig.name}`;
const description = "Writing and notes — coming soon.";
---

<BaseLayout title={title} description={description} pathname={Astro.url.pathname}>
  <section class:list={[siteChromeGutters, siteChromeInner, "py-16"]}>
    <h1 class="heading-gradient text-3xl font-extrabold tracking-tighter sm:text-4xl">My Thoughts</h1>
    <p class="mt-4 max-w-xl text-pretty text-foreground-muted">
      This route is wired for Astro content collections in <code class="font-mono text-sm text-card-foreground"
        >content/blog</code
      >. Add MDX and a listing page when you are ready.
    </p>
  </section>
</BaseLayout>
